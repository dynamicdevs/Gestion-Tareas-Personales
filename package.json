{
  "name": "gestion-tareas-system",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema personal de gestión de tareas (Trabajo, Personal, Estudios)",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace server && npm run build --workspace client",
    "db:migrate": "npm run db:migrate --workspace server",
    "db:studio": "npm run db:studio --workspace server",
    "setup": "npm install && npm run db:migrate"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
